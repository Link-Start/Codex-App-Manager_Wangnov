{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex App Manager",
  "mainBinaryName": "codex-app-manager",
  "version": "0.1.22",
  "identifier": "io.github.wangnov.codexappmanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Codex App 管理器",
        "width": 400,
        "height": 640,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": true,
        "center": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost https://codexapp.agentsmirror.com https://github.com https://persistent.oaistatic.com"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "copyright": "Copyright (c) 2026 Wangnov",
    "shortDescription": "Codex App mirror install and update manager.",
    "longDescription": "A manager app for installing and updating mirrored official Codex desktop app packages.",
    "targets": ["nsis", "dmg", "app"],
    "resources": ["resources/*"],
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "installMode": "currentUser",
        "template": "installer/installer.nsi",
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "languages": [
          "English",
          "SimpChinese",
          "TradChinese",
          "Japanese",
          "Korean",
          "French",
          "German",
          "Spanish",
          "PortugueseBR",
          "Russian",
          "Arabic"
        ],
        "customLanguageFiles": {
          "English": "installer/languages/English.nsh",
          "SimpChinese": "installer/languages/SimpChinese.nsh",
          "TradChinese": "installer/languages/TradChinese.nsh",
          "Japanese": "installer/languages/Japanese.nsh",
          "Korean": "installer/languages/Korean.nsh",
          "French": "installer/languages/French.nsh",
          "German": "installer/languages/German.nsh",
          "Spanish": "installer/languages/Spanish.nsh",
          "PortugueseBR": "installer/languages/PortugueseBR.nsh",
          "Russian": "installer/languages/Russian.nsh",
          "Arabic": "installer/languages/Arabic.nsh"
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIxQThDQzg4QjlFNjE5QTEKUldTaEdlYTVpTXlvSWNQYVRHMjRNQmtLQ25HdE1aV2FoY0hLSldsZHpHM3NMYkJHMk8zVDR0WDEK",
      "endpoints": [
        "https://codexapp.agentsmirror.com/manager/latest.json",
        "https://github.com/Wangnov/Codex-App-Manager/releases/latest/download/latest.json"
      ]
    }
  }
}
